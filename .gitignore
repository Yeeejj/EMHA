BACKUP/
~$*
.claude/

# ── Pipeline data outputs (never commit image data) ───────────────────────────
DATA/STAGING/
DATA/CROPS/*
DATA/PROCESSED/*
DATA/SPLITS/
!DATA/CROPS/.gitkeep
!DATA/PROCESSED/.gitkeep
FIGURES/*
!FIGURES/.gitkeep

# ── Model checkpoints ─────────────────────────────────────────────────────────
# Trained on real data; too large for git and not source code
models/*.pth
models/*.pkl

# ── Generated figures ─────────────────────────────────────────────────────────
# Regenerated by evaluator / trainer on every run
results/*.png
results/gradcam/

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.mypy_cache/
*.egg-info/
dist/
build/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
env/
.venv/
.env

# ── OS / IDE ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
